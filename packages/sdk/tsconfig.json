{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@common": ["src/common"],
      "@common/*": ["src/common/*"],
      "@thor": ["src/thor"],
      "@thor/*": ["src/thor/*"],
      "@viem": ["src/viem"],
      "@viem/*": ["src/viem/*"]
    }
  },
  "include": [
    "./src/**/*.ts",
    "./tests/**/*.ts",
    "./tsdown.config.ts"
  ]
}
